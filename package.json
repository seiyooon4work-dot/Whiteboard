{
  "name": "hafs-whiteboard-simulation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5176",
    "dev:clean": "rm -rf node_modules/.vite-5176 && vite --host 0.0.0.0 --port 5176 --force",
    "serve:5176": "npm run build && vite preview --host 127.0.0.1 --port 5176 --strictPort",
    "serve:5176:stop": "lsof -ti tcp:5176 | xargs kill -9 || true",
    "check": "tsc --noEmit --pretty false",
    "build": "npm run check && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4176 --strictPort"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@gsap/react": "^2.1.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "gsap": "^3.12.5",
    "lenis": "^1.1.14",
    "lucide-react": "^0.468.0",
    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.20",
    "fast-glob": "^3.3.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
